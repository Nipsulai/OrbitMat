&GLOBAL
  PROJECT scan
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep

  &DFT
    BASIS_SET_FILE_NAME /home/nikolai/OrbitMat/calc/src/input/basis/BASIS_MOLOPT_SCAN_DZ
    POTENTIAL_FILE_NAME /home/nikolai/OrbitMat/calc/src/input/potential/POTENTIAL_DZ_SCAN
    UKS {UKS}

    &MGRID
      CUTOFF 800
      REL_CUTOFF 70
    &END MGRID

    &QS
      EPS_DEFAULT 1.0E-12
    &END QS

    &POISSON
      PERIODIC XYZ
      PSOLVER PERIODIC
    &END POISSON

    &XC
      &XC_FUNCTIONAL
        &MGGA_X_R2SCAN
        &END MGGA_X_R2SCAN
        &MGGA_C_R2SCAN
        &END MGGA_C_R2SCAN
      &END XC_FUNCTIONAL
      &XC_GRID
        XC_DERIV SPLINE3
        XC_SMOOTH_RHO SPLINE3
      &END XC_GRID
    &END XC

    &KPOINTS
      SCHEME MONKHORST-PACK {KX} {KY} {KZ}
      FULL_GRID T
      SYMMETRY T
    &END KPOINTS

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1e-6
      MAX_SCF 200

      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION

      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        BETA 0.8
        NBROYDEN 10
      &END MIXING

      &SMEAR
        ELECTRONIC_TEMPERATURE  500
        METHOD FERMI_DIRAC
      &END SMEAR

      ADDED_MOS 10
    &END SCF

    &PRINT
      &MO
        EIGENVALUES T
        OCCNUMS T
        FILENAME {FOLDER}/eigenvalues
        ADD_LAST NUMERIC
        &EACH
          QS_SCF -1
        &END EACH
      &END MO

      &KS_CSR_WRITE
        REAL_SPACE {REAL_SPACE}
        BINARY T
        &EACH
          QS_SCF -1
        &END EACH
        FILENAME {FOLDER}/
      &END KS_CSR_WRITE

      &S_CSR_WRITE
        REAL_SPACE {REAL_SPACE}
        BINARY T
        &EACH
          QS_SCF -1
        &END EACH
        FILENAME {FOLDER}/
      &END S_CSR_WRITE

      &P_CSR_WRITE
        REAL_SPACE {REAL_SPACE}
        BINARY T
        &EACH
          QS_SCF -1
        &END EACH
        FILENAME {FOLDER}/
      &END P_CSR_WRITE

      &HCORE_CSR_WRITE
        REAL_SPACE {REAL_SPACE}
        BINARY T
        &EACH
          QS_SCF -1
        &END EACH
        FILENAME {FOLDER}/
      &END HCORE_CSR_WRITE
    &END PRINT

  &END DFT

  &SUBSYS

    &CELL
      PERIODIC XYZ
      CELL_FILE_FORMAT CIF
      CELL_FILE_NAME {CIF_PATH}
    &END CELL

    &TOPOLOGY
      COORD_FILE_FORMAT CIF
      COORD_FILE_NAME {CIF_PATH}
      &GENERATE
        REORDER T
      &END GENERATE
    &END TOPOLOGY

{KINDS}

  &END SUBSYS
&END FORCE_EVAL
