&GLOBAL
  PROJECT dz_mol
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep

  &DFT
    BASIS_SET_FILE_NAME {BASIS_SET_FILE_NAME}
    POTENTIAL_FILE_NAME {POTENTIAL_FILE_NAME}
    UKS {UKS}

    &MGRID
      CUTOFF {CUTOFF}
      REL_CUTOFF 60
    &END MGRID

    &QS
      EPS_DEFAULT 1.0E-10
    &END QS

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-6
      MAX_SCF 100

      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION

      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.4
        NBROYDEN 8
      &END MIXING

      ADDED_MOS 10

      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR

    &END SCF

    &PRINT
      &KS_CSR_WRITE
        REAL_SPACE T
        BINARY T
        FILENAME {FOLDER}/
        &EACH
          QS_SCF -1
        &END EACH
      &END KS_CSR_WRITE

      &S_CSR_WRITE
        REAL_SPACE T
        BINARY T
        FILENAME {FOLDER}/
        &EACH
          QS_SCF -1
        &END EACH
      &END S_CSR_WRITE

      &P_CSR_WRITE
        REAL_SPACE T
        BINARY T
        FILENAME {FOLDER}/
        &EACH
          QS_SCF -1
        &END EACH
      &END P_CSR_WRITE

      &HCORE_CSR_WRITE
        REAL_SPACE T
        BINARY T
        FILENAME {FOLDER}/
        &EACH
          QS_SCF -1
        &END EACH
      &END HCORE_CSR_WRITE

    &END PRINT

  &END DFT

  &SUBSYS
    &CELL
      ABC {AX} {AY} {AZ}
      PERIODIC NONE
    &END CELL

    &TOPOLOGY
      COORD_FILE_FORMAT XYZ
      COORD_FILE_NAME {XYZ_PATH}
      &CENTER_COORDINATES  # Crucial for MT solver and padding!
      &END CENTER_COORDINATES
      &GENERATE
        REORDER T
      &END GENERATE
    &END TOPOLOGY

{KINDS}

  &END SUBSYS
&END FORCE_EVAL